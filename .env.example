# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== Neo4j AuraDB 配置 =====
# 使用 Neo4j AuraDB（云托管），连接字符串格式：
# neo4j+s://<username>:<password>@<instance-id>.neo4j.io
# 或 bolt+s://<username>:<password>@<instance-id>.neo4j.io

# 示例（请替换为你的实际值）：
NEO4J_URI=neo4j+s://username:password@xxxxx.databases.neo4j.io
# 或使用 Bolt 协议：
# NEO4J_URI=bolt+s://username:password@xxxxx.databases.neo4j.io

# ===== 或使用本地 Neo4j =====
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_neo4j_password_here

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== OpenMAIC 虚拟课堂配置 =====
OPENMAIC_BASE_URL=http://localhost:3001
OPENMAIC_TIMEOUT=300
# OpenMAIC 项目路径（供 npm run dev:all 启动脚本使用，默认查找同级目录 ../OpenMAIC）
OPENMAIC_DIR=F:\AI Projects\OpenMAIC